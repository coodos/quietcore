#!/bin/bash
# Dynamically switches ACPI platform profile, EPP and turbo boost based on CPU
# utilization, GPU utilization, and temperature.
#
# States:
#   quiet  - idle:       quiet profile,       balance_power EPP,        turbo off
#   gpu    - GPU active: balanced profile,    balance_performance EPP,  turbo on
#   load   - CPU active: performance profile, performance EPP,          turbo on

QUIET_PROFILE="quiet"
GPU_PROFILE="balanced"
CPU_PROFILE="performance"

QUIET_EPP="balance_power"
GPU_EPP="balance_performance"
CPU_EPP="performance"

CPU_HIGH=40        # % CPU utilization to enter load state
CPU_LOW=15         # % CPU utilization hysteresis
GPU_HIGH=30        # % GPU utilization to enter gpu state (of freq range)
GPU_LOW=10         # % GPU utilization hysteresis
TEMP_THRESHOLD=72  # degrees C - sustain current state until CPU cools below this
COOLDOWN=15        # seconds both CPU and GPU below low threshold before going quiet
POLL=2             # seconds between samples

PROFILE_NODE="/sys/firmware/acpi/platform_profile"
TURBO_NODE="/sys/devices/system/cpu/intel_pstate/no_turbo"
EPP_NODE="cpufreq/energy_performance_preference"
GT0_ACT="/sys/devices/pci0000:00/0000:00:02.0/tile0/gt0/freq0/act_freq"
GT0_MIN="/sys/devices/pci0000:00/0000:00:02.0/tile0/gt0/freq0/rpn_freq"
GT0_MAX="/sys/devices/pci0000:00/0000:00:02.0/tile0/gt0/freq0/rp0_freq"

current_profile=""
current_turbo=""
last_active=0
state="quiet"

read_stat() {
    awk '/^cpu /{print $2,$3,$4,$5,$6,$7,$8,$9; exit}' /proc/stat
}

set_profile() {
    local want="$1"
    [[ "$want" == "$current_profile" ]] && return
    echo "$want" > "$PROFILE_NODE" && current_profile="$want"
}

set_turbo() {
    local want="$1"
    [[ "$want" == "$current_turbo" ]] && return
    echo "$want" > "$TURBO_NODE" && current_turbo="$want"
}

set_epp() {
    local want="$1"
    # No caching - TLP's udev rule can override EPP between our writes,
    # causing the tracking variable to lie. Always write every iteration.
    for cpu in /sys/devices/system/cpu/cpu[0-9]*; do
        [[ -f "$cpu/$EPP_NODE" ]] && echo "$want" > "$cpu/$EPP_NODE"
    done
}

on_ac() {
    grep -qr '^1$' /sys/class/power_supply/*/online 2>/dev/null
}

cpu_temp() {
    for zone in /sys/class/thermal/thermal_zone*; do
        if [[ "$(cat "$zone/type" 2>/dev/null)" == "x86_pkg_temp" ]]; then
            awk '{printf "%d", $1/1000}' "$zone/temp"
            return
        fi
    done
    echo 0
}

cpu_usage() {
    read -r u1 n1 s1 i1 w1 r1 x1 t1 <<< "$(read_stat)"
    sleep "$POLL"
    read -r u2 n2 s2 i2 w2 r2 x2 t2 <<< "$(read_stat)"
    local total=$(( (u2+n2+s2+i2+w2+r2+x2+t2) - (u1+n1+s1+i1+w1+r1+x1+t1) ))
    local idle=$(( i2+w2 - i1-w1 ))
    (( total == 0 )) && echo 0 || echo $(( (total - idle) * 100 / total ))
}

# GPU load as % of usable frequency range (act - min) / (max - min).
# Returns 0 if sysfs nodes are not available.
gpu_usage() {
    [[ -f "$GT0_ACT" && -f "$GT0_MIN" && -f "$GT0_MAX" ]] || echo 0 && return
    local act min max range
    act=$(cat "$GT0_ACT")
    min=$(cat "$GT0_MIN")
    max=$(cat "$GT0_MAX")
    range=$(( max - min ))
    (( range <= 0 )) && echo 0 || echo $(( (act - min) * 100 / range ))
}

apply_state() {
    case "$state" in
        load)
            set_turbo 0
            set_epp "$CPU_EPP"
            set_profile "$CPU_PROFILE"
            ;;
        gpu)
            set_turbo 0
            set_epp "$GPU_EPP"
            set_profile "$GPU_PROFILE"
            ;;
        quiet)
            set_turbo 1
            set_epp "$QUIET_EPP"
            set_profile "$QUIET_PROFILE"
            ;;
    esac
}

# Apply quiet state immediately on start regardless of what TLP left behind.
apply_state

while true; do
    cpu=$(cpu_usage)   # sleeps POLL seconds internally
    gpu=$(gpu_usage)
    temp=$(cpu_temp)

    if (( gpu >= GPU_HIGH )); then
        # GPU active - gaming or GPU compute. Use balanced, not full performance.
        state="gpu"
        last_active=$SECONDS
    elif (( cpu >= CPU_HIGH )); then
        # CPU active - compiling, encoding, etc. Full performance.
        state="load"
        last_active=$SECONDS
    elif (( cpu >= CPU_LOW || gpu >= GPU_LOW || temp >= TEMP_THRESHOLD )); then
        # Hysteresis zone or still hot - stay in current state, reset cooldown.
        last_active=$SECONDS
    elif (( SECONDS - last_active >= COOLDOWN )); then
        state="quiet"
    fi

    apply_state
done
